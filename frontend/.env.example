# EduManage Pro Frontend Configuration

# Backend API URL - Change this to match your backend server
REACT_APP_API_URL=http://localhost:8080/api

# For production deployment, use your actual backend URL:
# REACT_APP_API_URL=https://your-backend-domain.com/api

# For development with a different port:
# REACT_APP_API_URL=http://localhost:9090/api